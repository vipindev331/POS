# Copy to .env and adjust. All values have safe dev defaults if omitted.
PORT=4000
NODE_ENV=development

# JWT — CHANGE THESE IN PRODUCTION
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# SQLite database file (relative to backend/)
DB_PATH=./data/pos.sqlite

# This branch/terminal identity (used for invoice-number allocation)
BRANCH_ID=BR01

# CORS allowed origins (comma-separated). '*' allows all (dev only).
CORS_ORIGINS=*
